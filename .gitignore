*.gerber
*.gbr
*.drl
*.txt
*.pos

*.xml
# Netlist files
*.net
# Cache files
*-cache.lib
*-rescue.lib
*-backup.*
# KiCad 6
*/**/fp-info-cache
*/**/fp-info-table
# KiCad 5 and earlier
*-cache.lib
*-rescue.lib
*-backup.*
# KiCad 3D viewer
3dmodels/*.wrl
3dmodels/*.step
3dmodels/*.stp
3dmodels/*.stl
# Simulation

# Temporary files
*.bak
*.tmp
# OS-specific
.DS_Store
Thumbs.db
# KiCad project files (optional, but often ignored)
#*.kicad_pro
# User-specific settings
*-user.kicad_pro
# KiCad 5 and earlier project files
*.pro
# Netlist files (alternative extension)
*.net
*.xml
# Pick and place
*.pos
# Drill files
*.drl
# Gerber files (alternative extensions)
*.gbr
*.gbrjob
# 3D model files (alternative extensions)
#*.step # model is a step this time
*.stp
*.stl
*.wrl
*.x3d
*.x3dz
*.vrml
# Simulation results

# Temporary and backup files
*.bak
*.tmp
*-backup.*
*-rescue.lib
*-cache.lib
# OS and editor files
.DS_Store
Thumbs.db
*.swp
*~
# KiCad 6 specific
**/fp-info-cache
**/fp-info-table

*.lck
# Allow BOM.csv
!BOM.csv
# Allow main KiCad project files
!kicad/FTDIboard.kicad_pro
#!kicad/*.kicad_sch # Allow schematic files
!kicad/FTDIboard.kicad_pcb
!kicad/FTDIboard.kicad_prl

# Allow supporting KiCad files
!kicad/fp-lib-table

# Allow custom footprints
!kicad/customimages/

# Restore backups (auto-generated by KiCad)
kicad/_restore_backup_*/
